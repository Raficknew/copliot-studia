name: email-validation
description: Skill dla walidacji adresów email i testowania
topics:
  - validation
  - email
  - regex
  - testing
applyTo:
  - path: "**/validators/**"
  - path: "**/test_*subscribers*"
  - path: "**/test_*validators*"
languageDetection:
  preferredLanguage: python
  patterns:
    - "@"
    - "email"
